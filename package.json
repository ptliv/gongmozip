{
  "name": "contest-with-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "seo:static": "python scripts/deploy/generate_static_seo_files.py",
    "preview:cloudflare": "npm run seo:static && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cloudflare": "npm run seo:static && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload:cloudflare": "npm run seo:static && opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "test:domain": "node tests/domain_logic.test.cjs",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.13.1",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.441.0",
    "next": "14.2.5",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wrangler": "4.49.1"
  }
}
