# Supabase — 프로젝트 설정 > API에서 확인
# https://app.supabase.com/project/_/settings/api

# 브라우저 노출 OK (anon key는 RLS로 보호됨)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 서버 전용 (절대 클라이언트에 노출 금지)
# 관리자 작업(insert/update/delete)에 사용 — RLS bypass
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# 관리자 허용 이메일 (쉼표로 구분, 비워두면 모든 인증 사용자 허용)
ADMIN_ALLOWED_EMAILS=admin@example.com

# 사이트 기본 URL (sitemap.xml 생성에 사용)
NEXT_PUBLIC_SITE_URL=https://www.gongmozip.com
NEXT_PUBLIC_ALTERNATE_SITE_URLS=https://gongmozip.com

# 크롤러 상세 보강
CRAWLER_FETCH_OFFICIAL_DETAIL=true
CRAWLER_OFFICIAL_TEXT_CHARS=900
CRAWLER_DESCRIPTION_CHARS=2600

# Threads publisher (optional; values can also be reused from the old Threads app DB)
THREADS_PROFILE_NAME=daytem_room
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=
THREADS_SHORTENER=tinyurl
THREADS_TARGET_URL=https://www.gongmozip.com/contests
THREADS_DISCORD_WEBHOOK_URL=
THREADS_DAILY_LIMIT=10
THREADS_SCHEDULE_TIMES=09:10,12:30,15:30,18:30,21:30
